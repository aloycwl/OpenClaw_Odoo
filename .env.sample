# Copy this file to .env and fill values.

# Odoo API key used when --allow-post is enabled.
ODOO_API_KEY=your_odoo_api_key_here

# AI chat configuration used when --use-ai is enabled.
AI_CHAT_URL=https://your-chat-provider.example.com/v1/chat/completions
AI_MODEL=gpt-4o-mini
AI_SECRET=your_ai_secret_here
